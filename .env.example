# Alpha Scanner — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored so your secrets stay private.

# ─── Alpaca Paper Trading ───────────────────────────────────
# Get these from https://app.alpaca.markets (Paper Trading mode)
ALPACA_API_KEY=your-paper-api-key-here
ALPACA_SECRET_KEY=your-paper-secret-key-here

# ─── Gmail SMTP (for daily digest emails) ───────────────────
# Create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on your Google account)
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional: recipient address. Defaults to GMAIL_ADDRESS if unset.
ALERT_EMAIL_TO=your-email@gmail.com
