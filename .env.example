# Alpha Scanner — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is gitignored so your keys stay private.

# Alpaca Paper Trading API credentials
# Get these from https://app.alpaca.markets (Paper Trading mode)
ALPACA_API_KEY=your-paper-api-key-here
ALPACA_SECRET_KEY=your-paper-secret-key-here

# Optional: email alerts via Resend
RESEND_API_KEY=your-resend-api-key-here
ALERT_EMAIL_TO=your-email@example.com
